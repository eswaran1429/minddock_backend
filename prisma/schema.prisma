generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  name      String?
  email     String   @unique
  password  String
  createdAt DateTime @default(now())

  memories Memory[]
}

model Memory {
  id          Int      @id @default(autoincrement())

  title       String
  content     String
  imagePath   String?
  type        String @default("notes")

  memoryDate  DateTime @default(now())
  updatedAt   DateTime? @updatedAt

  tags        String[] @default([])
  userId      Int
  user        User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}